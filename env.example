
# !anything envsubst uses must be exported
# new user name linux
SITE_NAME="Toggn Site Deployment Test"
export NEW_USER=testuser

# domain name
export NEW_DOMAIN=example.com
SITE_URL=https://$NEW_DOMAIN


# PHP
export PHP_VERSION=8.5
PHPFPM_SERVICE=php$PHP_VERSION-fpm.service

# root for the web files
WWW_DIR=/var/www/$NEW_USER

# Wordpress
WP_TABLE_PREFIX=wp_`pwgen -s -B -c -n 5 1`_
WP_ADMIN_USER=toggen_admin
WP_ADMIN_EMAIL=james@toggen.com.au

# Mysql 
MYSQL_DB=${NEW_USER}db
MYSQL_USER=${NEW_USER}dbuser
MYSQL_PWD="" # mysql root password here
DB_HOST=localhost

# this is the wordpress user pass
MYSQL_PASS=`pwgen -s -B -c -n 40 1 | sed s/./*$/5`

# location of templates
NGINX_CONF_TEMPLATE=templates/wp-nginx.conf
PHPFPM_CONF_TEMPLATE=templates/php-fpm.conf
LOGROTATE_CONF_TEMPLATE=templates/logrotate.conf

# location of where to copy nginx and php-fpm conf files
NGINX_CONF_DIR=/etc/nginx/sites-available
SITES_ENABLED=/etc/nginx/sites-enabled
PHPFPM_CONF_DIR=/etc/php/$PHP_VERSION/fpm/pool.d
LOGROTATE_DIR=/etc/logrotate.d

# full destination path for the conf files
NEW_NGINX_CONF=$NGINX_CONF_DIR/$NEW_USER.conf
NEW_PHPFPM_CONF=$PHPFPM_CONF_DIR/$NEW_USER.conf
NEW_LOGROTATE_CONF=$LOGROTATE_DIR/$NEW_USER

